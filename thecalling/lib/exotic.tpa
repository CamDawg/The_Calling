COPY_EXISTING ~%tutu_var%meilum.cre~ ~override~ // adds katana +0 to Meilum by replacing primary weapon
//  REPLACE_CRE_ITEM ~sw1h43~ #0 #0 #0 ~NONE~ ~WEAPON1~ EQUIP
  LPF ALTER_CREATURE_ITEM 
    STR_VAR item       = "sw1h43"
            match_item = EVAL "%tutu_var%sw1h05"
    RET     meilum_slot = replaced_slot 
            meilum_item = replaced_item
  END 
  
ACTION_IF meilum_slot < 0 BEGIN // if <0, item was not placed on meilum
  // plan b for placement
END

