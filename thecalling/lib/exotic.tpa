/////                                                  \\\\\
///// remove bgee exotics, if indicated                \\\\\
/////                                                  \\\\\

ACTION_IF remove_bgee_exotics BEGIN

  // why use ALTER_CREATURE_ITEM instead of REPLACE_CRE_ITEM? If another mod has 
  // swapped the weapon, then I don't want to overwrite their weapon selection

  //COPY_EXISTING ~rndwep.2da~ ~override~
  // has katana +1, wakizashi +1 available, but also the case for BGT/Tutu so leave alone

  COPY_EXISTING ~inn2616.sto~  ~override~ // candlekeep inn
                ~sto1112.sto~  ~override~ // general store in sw bg
    REMOVE_STORE_ITEM ~sw1h43~ ~sw1h46~ // katana, waki 
    BUT_ONLY

  COPY_EXISTING ~inn2616.sto~  ~override~ // candlekeep inn
                ~sto4803.sto~  ~override~ // nashkel store
    REMOVE_STORE_ITEM ~sw1h48~ // ninjato
    BUT_ONLY

  COPY_EXISTING ~droth.cre~    ~override~ // droth
                ~ogrema_d.cre~ ~override~ // generic ogre mage
    LPF ALTER_CREATURE_ITEM STR_VAR match_item = sw1h43 item = sw1h01 END // bastard sword for katana 
    BUT_ONLY

  COPY_EXISTING ~kahrk.cre~    ~override~ // kahrk
    LPF ALTER_CREATURE_ITEM STR_VAR match_item = sw1h43 item = sw1h04 END // long sword for katana
    BUT_ONLY

  COPY_EXISTING ~ogrema03.cre~ ~override~ // generic ogre mage
    LPF ALTER_CREATURE_ITEM STR_VAR match_item = sw1h44 item = sw1h01 END // bastard sword for katana +1
    BUT_ONLY

  COPY_EXISTING ~safana.cre~  ~override~ // safana
                ~safana4.cre~ ~override~ // safana
                ~safana6.cre~ ~override~ // safana
    LPF ALTER_CREATURE_ITEM STR_VAR match_item = sw1h48 item = sw1h20 END // scimitar for ninjato
    BUT_ONLY

  COPY_EXISTING ~senjack.cre~ ~override~ // Senjak - dual wields wakizashi
    LPF ALTER_CREATURE_ITEM STR_VAR match_item = sw1h47 item = sw1h22 END // scimitar +1 for waki +1
    LPF ALTER_CREATURE_ITEM STR_VAR match_item = sw1h46 item = sw1h20 END // scimitar for waki
    BUT_ONLY

  // bg sewers, east - remove ninjato +1 from container3
  EXTEND_BOTTOM ~%ESewers_BCS%.bcs~ ~thecalling/baf/ar0226.baf~

END 

